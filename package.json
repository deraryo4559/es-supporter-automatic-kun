{
  "name": "es-supporter-automatic-kun",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "node server/gemini-proxy.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "tsc -b --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "diff": "^8.0.2",
    "lucide-react": "^0.561.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.3"
  },
  "devDependencies": {
    "@types/diff": "^8.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  }
}
